---
// src/components/LanguagePicker.astro
interface Props {
  mode?: "l3" | "roas";
}
const { mode = "l3" } = Astro.props;
const { lang } = Astro.params;
const prefix = mode === "roas" ? "/networks-lab/roas" : "/networks-lab";
---

<div class="flex gap-2 mb-8 p-1 bg-white/5 rounded-lg border border-white/10">
  <a
    href={`${prefix}/es/`}
    class={`flex-1 py-1 text-[10px] font-bold rounded transition-all uppercase tracking-tighter text-center ${lang === 'es' ? 'active' : ''}`}
  >
    Español
  </a>
  <a
    href={`${prefix}/de/`}
    class={`flex-1 py-1 text-[10px] font-bold rounded transition-all uppercase tracking-tighter text-center ${lang === 'de' ? 'active' : ''}`}
  >
    Deutsch
  </a>
</div>

<style>
  a {
    color: #64748b;
    text-decoration: none;
  }
  a:hover {
    color: #f8fafc;
  }
  a.active {
    background-color: rgba(59, 130, 246, 0.2);
    color: #3b82f6;
  }
</style>
