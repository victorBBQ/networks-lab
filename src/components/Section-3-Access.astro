---
import Remember from "./Remember.astro";
import CliSection from "./CliSection.astro"; // El componente pequeñito para las cajas de código

const buildings = [
  { 
    side: "WEST", 
    name: "SWITCH EV-L", 
    vlanId: "13", 
    vlanName: "West_Azul", 
    mgmtIp: "10.0.8.11", 
    desc: "Hauptlink_zu_GV-L" 
  },
  { 
    side: "OST", 
    name: "SWITCH EV-R", 
    vlanId: "23", 
    vlanName: "Ost_Lila", 
    mgmtIp: "10.0.8.22", 
    desc: "Hauptlink_zu_GV-R" 
  }
];
---
<section id="zugang" class="mb-32">
  <h2 class="mb-10 pl-4 text-3xl font-bold text-white tracking-tighter border-l-4 border-blue-500 uppercase">
    03. Configuración de Switches de Acceso (2960 - L2)
  </h2>

  <div class="grid gap-8 lg:grid-cols-2">
    {buildings.map((b) => (
      <div class="p-8 bg-slate-900/50 rounded-3xl border border-white/5 shadow-2xl">
        <h3 class="mb-6 text-xl font-bold text-blue-500 uppercase">
          {b.name} <span class="text-white font-medium">({b.side})</span>
        </h3>

        <div class="space-y-8 font-mono text-[12px] leading-relaxed">
          <Remember />
          
          <CliSection title="Creación de VLANs">
            <p>vlan 8 name Management</p>
            <p>vlan {b.vlanId} name {b.vlanName}</p>
          </CliSection>

          <CliSection title="Seguridad de Puertos">
            <p>interface range fa0/1 - 24</p>
            <p class="pl-4">switchport mode access</p>
            <p class="pl-4">switchport access vlan {b.vlanId}</p>
            <p class="pl-4">spanning-tree portfast</p>
            <p class="pl-4">switchport port-security</p>
            <p class="pl-4">switchport port-security maximum 2</p>
            <p class="pl-4">switchport port-security mac-address sticky</p>
            <p class="pl-4">switchport port-security violation shutdown</p>
            <p class="pl-4">spanning-tree bpduguard enable</p>
            <p class="pl-4">exit</p>
          </CliSection>

          <CliSection title="Enlaces Trunk y Gestión">
            <p>interface gig0/1</p>
            <p class="pl-4">description {b.desc}</p>
            <p class="pl-4">switchport mode trunk</p>
            <p class="pl-4">exit</p>
            <br />
            <p>interface vlan 8</p>
            <p class="pl-4">ip address {b.mgmtIp} 255.255.255.0</p>
            <p class="pl-4">no shut</p>
            <p class="pl-4">exit</p>
            <br />
            <p>ip default-gateway 10.0.8.1</p>
          </CliSection>
        </div>
      </div>
    ))}
  </div>
</section>