---
const servers = [
  { 
    title: "Servidor West", 
    floor: "Piso 4", 
    ip: "10.0.99.10", 
    color: "emerald", 
    dc: "Data Center A", 
    logs: "GV-L y EV-L" 
  },
  { 
    title: "Servidor Ost", 
    floor: "Piso 6", 
    ip: "10.0.99.20", 
    color: "pink", 
    dc: "Data Center B", 
    logs: "GV-R y EV-R" 
  }
];
---
<section id="servers" class="mb-32">
  <h2 class="mb-8 pl-4 text-3xl font-bold text-white border-l-4 border-emerald-500 uppercase">
    08. Configuración de Servicios Finales (Servidores)
  </h2>
  
  <div class="grid gap-8 md:grid-cols-2">
    {servers.map((s) => (
      <div class={`p-8 bg-slate-900/50 rounded-3xl border border-${s.color}-500/20 shadow-2xl`}>
        <div class="flex justify-between items-start mb-4">
          <h3 class={`text-lg font-bold text-${s.color}-400 uppercase italic`}>{s.title} ({s.floor})</h3>
          <span class={`px-2 py-1 rounded bg-${s.color}-500/10 text-${s.color}-500 text-[10px] font-bold uppercase border border-${s.color}-500/20`}>{s.dc}</span>
        </div>
        
        <ul class="space-y-3 text-sm text-slate-400 font-mono">
          <li class="flex justify-between border-b border-white/5 pb-1"><span>Dirección IP:</span> <span class="text-white">{s.ip}</span></li>
          <li class="flex justify-between border-b border-white/5 pb-1"><span>Máscara:</span> <span class="text-white">255.255.255.0</span></li>
          <li class="flex justify-between border-b border-white/5 pb-1"><span>Gateway:</span> <span class="text-white">10.0.99.1</span></li>
        </ul>

        <div class="mt-6 p-4 bg-black/40 rounded-xl space-y-4">
          <div>
            <p class={`text-base text-${s.color}-500 font-bold uppercase mb-2`}>// Servicios a Activar</p>
            <p class="text-sm text-slate-300 italic">- <strong>SYSLOG:</strong> Recolecta eventos de {s.logs}.</p>
            <p class="text-sm text-slate-300 italic">- <strong>NTP:</strong> Fuente de tiempo primaria.</p>
          </div>
          </div>
      </div>
    ))}
  </div>
</section>