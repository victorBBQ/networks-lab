</html>

<style is:global>
  section[id] {
    scroll-margin-top: 100px;
  }

  /* En pantallas grandes (PC) puedes ajustarlo si quieres más aire */
  @media (min-width: 1024px) {
    section[id] {
      scroll-margin-top: 40px;
    }
  }
      .nav-link.active {
        color: #3b82f6 !important;
        border-left: 2px solid #3b82f6;
        padding-left: 8px;
        margin-left: -10px;
      }
      html { scroll-behavior: smooth; }
      ::-webkit-scrollbar { width: 8px; }
      ::-webkit-scrollbar-track { background: #020617; }
      ::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 10px; }
      ::-webkit-scrollbar-thumb:hover { background: #334155; }
</style>

<script>
    import translations from "../data/languages.json";

    const currentLang = document.documentElement.lang as "es" | "de";

    // 2. MENÚ MÓVIL
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const aside = document.getElementById('main-aside');
    const overlay = document.getElementById('menu-overlay');
    const menuIcon = document.getElementById('menu-icon');

    function toggleMenu() {
      if (!aside || !overlay || !menuIcon) return;

      const isHidden = aside.classList.contains('hidden');

      if (isHidden) {
        // ABRIR
        aside.classList.remove('hidden');
        overlay.classList.remove('hidden');
        menuIcon.setAttribute('d', 'M6 18L18 6M6 6l12 12');
        document.body.style.overflow = 'hidden';
      } else {
        // CERRAR
        aside.classList.add('hidden');
        overlay.classList.add('hidden');
        menuIcon.setAttribute('d', 'M4 6h16M4 12h16m-7 6h7');
        document.body.style.overflow = '';
      }
    }

    if(mobileBtn) mobileBtn.onclick = toggleMenu;
    if(overlay) overlay.onclick = toggleMenu;

    // 3. SCROLL ACTIVO Y CIERRE LINKS
const navLinks = document.querySelectorAll('.nav-link');
    const sections = document.querySelectorAll('section[id]');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          navLinks.forEach(l => {
            l.classList.remove('active');

            // CORRECCIÓN: Buscamos si el href termina con el ID de la sección actual
            const href = l.getAttribute('href');
            if (href && href.endsWith(`#${e.target.id}`)) {
              l.classList.add('active');
            }
          });
        }
      });
    }, { rootMargin: '-20% 0px -70% 0px' });

    sections.forEach(s => observer.observe(s));

    // 4. TOOLTIPS
    const reasons = translations[currentLang].reasons;
    const common = translations[currentLang].common;
    const tooltip = document.createElement("div");
    tooltip.className = "fixed hidden z-[200] p-3 bg-slate-800 border border-emerald-500/50 text-emerald-400 text-xs rounded-lg shadow-2xl max-w-xs italic pointer-events-none";
    document.body.appendChild(tooltip);

    document.querySelectorAll('div[class*="bg-black/40"] p, div.overflow-x-auto p').forEach((p: any) => {
      const command = p.innerText.replace(/\u00a0/g, " ").trim();
      if (reasons[command]) {
        p.classList.add("cursor-help", "hover:text-emerald-400");
        p.onmouseenter = () => {
          tooltip.innerHTML = `<strong class="block text-white mb-1 uppercase text-[10px]">${common.why}</strong>${reasons[command]}`;
          tooltip.classList.remove("hidden");
        };
        p.onmousemove = (e) => {
          tooltip.style.left = e.clientX + 15 + "px";
          tooltip.style.top = e.clientY + 15 + "px";
        };
        p.onmouseleave = () => tooltip.classList.add("hidden");
      }
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth >= 1024) {
        // Si la pantalla es grande, nos aseguramos de que el aside NO esté oculto
        // y que el body pueda hacer scroll
        aside?.classList.remove('hidden');
        overlay?.classList.add('hidden');
        document.body.style.overflow = '';

        // Reseteamos el icono a hamburguesa por si acaso
        if (menuIcon) menuIcon.setAttribute('d', 'M4 6h16M4 12h16m-7 6h7');
      } else {
        // Si volvemos a móvil desde PC, lo ocultamos por defecto para evitar que se vea abierto
        aside?.classList.add('hidden');
      }
    });
  </script>