              </div>

              <div
                class="p-6 bg-black/40 rounded-2xl border border-pink-500/20"
              >
                <h4
                  class="text-xs font-bold text-pink-400 uppercase mb-4 italic"
                >
                  {t.sections.verify_section.isp_ost}
                </h4>
                <div class="font-mono text-[12px] text-blue-100 space-y-2">
                  <p>interface gig0/0</p>
                  <p class="pl-4 italic">
                    ip address 192.168.18.254 255.255.255.0
