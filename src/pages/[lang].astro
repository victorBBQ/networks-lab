---
import "../styles/global.css";
import translations from "../data/languages.json"
import Remember from "../components/Remember.astro";
import DeviceColumn from "../components/DeviceColumn.astro";
import CliBlock from "../components/CliBlock.astro";
import LanguagePicker from "../components/LanguagePicker.astro";
import ModePicker from "../components/ModePicker.astro";

export async function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'de' } },
  ];
}
const { lang } = Astro.params;
const t = translations[lang as "es" | "de"];
---

<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title> {t.title} | Cisco Lab</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Fira+Code&family=Inter:wght@400;700;900&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="text-slate-300 font-sans bg-[#020617] selection:bg-blue-500/30">

    <div class="lg:hidden fixed top-0 left-0 right-0 z-[100] bg-[#020617] border-b border-white/10 p-4 flex justify-between items-center">
      <div class="text-blue-500 font-black text-xl italic uppercase">
        CISCO<span class="text-white not-italic">_LAB</span>
      </div>
      <button id="mobile-menu-btn" class="p-2 text-slate-400 hover:text-white">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
        </svg>
      </button>
    </div>

    <div id="menu-overlay" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-[110] hidden lg:hidden"></div>

    <div class="flex">
      <aside
        id="main-aside"
        class="hidden lg:block overflow-y-auto h-screen w-80 p-8 bg-[#0a0f1e] border-r border-white/5 fixed z-[120] lg:z-auto"
      >
        <div class="mb-10 text-blue-500 font-black text-2xl tracking-tighter italic uppercase hidden lg:block">
          CISCO<span class="text-white not-italic">_LAB</span>
        </div>

        <LanguagePicker />
        <ModePicker mode="l3" lang={lang as string} />

        <nav class="space-y-4 text-xs font-bold tracking-widest text-white/90 uppercase">
          <a href={`/networks-lab/${lang}/#szenario`} class="nav-link block hover:text-blue-400 transition">{t.nav.scenario}</a>
          <a href={`/networks-lab/${lang}/#design`} class="nav-link block hover:text-blue-400 transition">{t.nav.design}</a>
          <a href={`/networks-lab/${lang}/#sicherheit`} class="nav-link block hover:text-blue-400 transition">{t.nav.security}</a>
          <a href={`/networks-lab/${lang}/#zugang`} class="nav-link block hover:text-blue-400 transition">{t.nav.access}</a>
          <a href={`/networks-lab/${lang}/#core`} class="nav-link block hover:text-blue-400 transition">{t.nav.core}</a>
          <a href={`/networks-lab/${lang}/#dynamisch`} class="nav-link block hover:text-blue-400 transition">{t.nav.dynamic}</a>
          <a href={`/networks-lab/${lang}/#statisch`} class="nav-link block hover:text-blue-400 transition">{t.nav.static}</a>
          <a href={`/networks-lab/${lang}/#routers`} class="nav-link block hover:text-blue-400 transition">{t.nav.routers}</a>
          <a href={`/networks-lab/${lang}/#servers`} class="nav-link block hover:text-blue-400 transition">{t.nav.servers}</a>
          <a href={`/networks-lab/${lang}/#laptops`} class="nav-link block hover:text-blue-400 transition">{t.nav.laptops}</a>
          <a href={`/networks-lab/${lang}/#wlan`} class="nav-link block hover:text-blue-400 transition">{t.nav.wireless}</a>

          <div class="pt-4">
            <a href={`/networks-lab/${lang}/#verificacion`} class="nav-link block p-2 text-blue-400 text-center tracking-tighter border border-blue-400/20 rounded hover:bg-blue-400/10 transition uppercase">
              {t.nav.verify}
            </a>
          </div>
        </nav>
      </aside>

      <main class="max-w-7xl w-full p-8 pt-20 lg:ml-80 lg:pt-16">
        <header class="mb-24">
                <h1 class="mb-6 text-6xl font-black text-white tracking-tighter leading-none md:text-8xl">
                  {t.hero.title1} <span class="text-blue-500">{t.hero.title2}</span>
                </h1>
                <p class="max-w-3xl text-xl text-slate-400 italic">{t.hero.subtitle}</p>
                <p class="max-w-3xl text-xl text-slate-400 italic mt-4">{t.hero.global} <span class="text-blue-400 font-mono">10.0.V.X /16</span></p>
        </header>

        <section id="szenario" class="mb-32">
         <h2 class="mb-10 pl-4 text-3xl font-bold text-white tracking-tighter border-l-4 border-blue-500 uppercase">
            {t.sections.s00.title}
          </h2>

          <div class="grid gap-6 md:grid-cols-2">
            <div
              class="p-8 bg-slate-900 rounded-3xl border border-white/5 shadow-2xl"
            >
              <h3 class="mb-4 text-lg font-bold text-blue-400 uppercase italic">
                {t.sections.s00.req_title}
              </h3>
              <ul class="space-y-3 text-sm text-slate-400 italic">
                <li class="flex items-start gap-3">
                  <span class="text-blue-500 font-bold">»</span>
                  <span
                    ><strong class="text-white">{t.sections.s00.req_1_bold}</strong>{t.sections.s00.req_1_text}</span
                  >
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-blue-500 font-bold">»</span>
                  <span
                    ><strong class="text-white">{t.sections.s00.req_2_bold}</strong>{t.sections.s00.req_2_text}</span
                  >
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-blue-500 font-bold">»</span>
                  <span
                    ><strong class="text-white">{t.sections.s00.req_3_bold}</strong>{t.sections.s00.req_3_text}</span
                  >
                </li>
              </ul>
            </div>

            <div
              class="p-8 bg-slate-900 rounded-3xl border border-blue-500/20 shadow-2xl"
            >
              <h3 class="mb-4 text-lg font-bold text-blue-400 uppercase italic">
                {t.sections.s00.tech_title}
              </h3>
              <ul class="space-y-3 text-sm text-slate-400 italic">
                <li class="flex items-start gap-3">
                  <span class="text-blue-500 font-bold">»</span>
                  <span
                    ><strong class="text-white">{t.sections.s00.tech_1_bold}</strong>{t.sections.s00.tech_1_text}</span
                  >
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-blue-500 font-bold">»</span>
                  <span
                    ><strong class="text-white">{t.sections.s00.tech_2_bold}</strong>{t.sections.s00.tech_2_text}</span
                  >
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-blue-500 font-bold">»</span>
                  <span
                    ><strong class="text-white">{t.sections.s00.tech_3_bold}</strong>{t.sections.s00.tech_3_text}</span
                  >
                </li>
              </ul>
            </div>
          </div>
        </section>

        <section id="design" class="mb-32">
          <h2 class="mb-10 pl-4 text-3xl font-bold text-white tracking-tighter border-l-4 border-blue-500 uppercase">
            {t.sections.s01.title}
          </h2>

          <div
            class="grid grid-cols-1 mb-8 gap-4 md:grid-cols-2 lg:grid-cols-4"
          >
            <div class="p-5 bg-slate-900 rounded-xl border border-white/5">
              <p class="mb-2 text-[12px] text-blue-400 font-mono uppercase">
                VLAN 08
              </p>
              <p class="font-bold text-white uppercase italic">{t.sections.s01.v08}</p>
            </div>
            <div class="p-5 bg-red-900/10 bg-slate-900 rounded-xl border border-red-500/20">
              <p class="mb-2 text-[12px] text-red-400 font-mono uppercase">
                VLAN 11 / 12
              </p>
              <p class="font-bold text-red-100 uppercase italic">
                {t.sections.s01.v12}
              </p>
            </div>
            <div
              class="p-5 bg-pink-900/10 bg-slate-900 rounded-xl border border-pink-500/20"
            >
              <p class="mb-2 text-[12px] text-pink-400 font-mono uppercase">
                VLAN 21 / 22
              </p>
              <p class="font-bold text-pink-100 uppercase italic">
                {t.sections.s01.v22}
              </p>
            </div>
            <div
              class="p-5 bg-emerald-900/10 bg-slate-900 rounded-xl border border-emerald-500/20"
            >
              <p class="mb-2 text-[12px] text-emerald-400 font-mono uppercase">
                VLAN 99
              </p>
              <p class="font-bold text-emerald-100 uppercase italic">{t.sections.s01.v99}</p>
            </div>
          </div>

          <div class="p-8 bg-slate-900 rounded-3xl border border-blue-500/20">
            <h3 class="mb-4 text-lg font-bold text-blue-400 uppercase italic">
              {t.sections.s01.core_spec_title}
            </h3>
            <ul class="space-y-3 text-sm leading-relaxed text-slate-300 italic">
              <li class="flex items-center gap-3">
                <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
                <span
                  ><strong class="text-white">{t.sections.s01.core_spec_1_bold}</strong> {t.sections.s01.core_spec_1_text}</span
                >
              </li>
              <li class="flex items-center gap-3">
                <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
                <span
                  ><strong class="text-white">{t.sections.s01.core_spec_2_bold}</strong> {t.sections.s01.core_spec_2_text}</span
                >
              </li>
            </ul>
          </div>
        </section>

        <section id="sicherheit" class="mb-32">
          <h2 class="mb-10 pl-4 text-3xl font-bold text-white tracking-tighter border-l-4 border-blue-500 uppercase">
            {t.sections.s02.title}
          </h2>
          <div
            class="overflow-hidden font-mono text-sm bg-slate-900 rounded-2xl border border-white/10 shadow-2xl"
          >
            <div
              class="flex px-4 py-2 bg-white/5 border-b border-white/10 justify-between"
            >
              <span
                class="text-xs text-slate-300 tracking-tighter uppercase italic"
                >IOS CLI — Security & VTY Setup</span
              >
              <div class="flex gap-2">
                <div class="w-2 h-2 bg-red-500/50 rounded-full"></div>
                <div class="w-2 h-2 bg-green-500/50 rounded-full"></div>
              </div>
            </div>
            <div class="overflow-x-auto p-8 text-white-300 leading-relaxed">
              <p>enable</p>
              <p>configure terminal</p>
              <p>hostname [Device_Name]</p>
              <p>ip domain-name lab.test</p>
              <p>no ip domain-lookup</p>
              <br />
              <p>username cisco privilege 15 secret cisco</p>
              <p>enable secret cisco</p>
              <p>service password-encryption</p>
              <br />
              <p>banner motd {t.sections.s02.motd}</p>
              <br />
              <p>access-list 10 permit 10.0.8.0 0.0.0.255</p>
              <br />
              <p>line console 0</p>
              <p class="pl-4">exec-timeout 0 0</p>
              <p class="pl-4">logging synchronous</p>
              <p class="pl-4">login</p>
              <p class="pl-4">exit</p>
              <br />
              <p>line vty 0 15</p>
              <p class="pl-4">exec-timeout 0 0</p>
              <p class="pl-4">login local</p>
              <p class="pl-4">transport input ssh</p>
              <p class="pl-4">access-class 10 in</p>
              <p class="pl-4">exit</p>
              <br />
              <p>logging buffered 8192</p>
              <p class="text-orange-400/80 italic text-[13px] mb-1">
                » {t.sections.s02.log_note}
              </p>
              <p>logging host [IP West-Server]</p>
              <p>logging host [IP Ost-Server]</p>
              <p>logging trap debugging</p>
              <p>logging source-interface vlan 8</p>
              <p class="text-orange-400/80 italic text-[13px] mb-1">
                » {t.sections.s02.ntp_note}
              </p>
              <p>ntp server [IP West-Server]</p>
              <p>ntp server [IP Ost-Server]</p>
              <p>clock timezone CET 1</p>
              <p>crypto key generate rsa</p>
              <p>ip ssh version 2</p>
            </div>
          </div>
        </section>

        <section id="zugang" class="mb-32">
          <h2 class="mb-10 pl-4 text-3xl font-bold text-white tracking-tighter border-l-4 border-blue-500 uppercase">
            {t.sections.s03.title}
          </h2>
          <div class="grid gap-8 lg:grid-cols-2">
            {["WEST", "OST"].map((side) => (
              <DeviceColumn name={side === "WEST" ? "SWITCH EV-L" : "SWITCH EV-R"} side={side} lang={lang as "es" | "de"}>

                <CliBlock title={t.sections.s03.vlan_title}>
                  <p><p>vlan 8</p></p>
                  <p><p>name Management</p></p>
                  <p>
                    {side === "WEST" ? "vlan 12" : "vlan 22"}
                  </p>
                  <p>
                    {side === "WEST" ? "name West_Blau" : "name Ost_Lila" }
                  </p>
                </CliBlock>

                <CliBlock title={t.sections.s03.security_title}>
                  <p>interface range fa0/1 - 24</p>
                  <p class="pl-4">switchport mode access</p>
                  <p class="pl-4">switchport access vlan {side === "WEST" ? "12" : "22"}</p>
                  <p class="pl-4">spanning-tree portfast</p>
                  <p class="pl-4">switchport port-security</p>
                  <p class="pl-4">switchport port-security maximum 2</p>
                  <p class="pl-4">switchport port-security mac-address sticky</p>
                  <p class="pl-4">switchport port-security violation shutdown</p>
                  <p class="pl-4">spanning-tree bpduguard enable</p>
                  <p class="pl-4">exit</p>
                </CliBlock>

                <CliBlock title={t.sections.s03.trunk_title}>
                  <p>interface gig0/1</p>
                  <p class="pl-4">
                    description {side === "WEST" ? t.sections.s03.desc_west_l : t.sections.s03.desc_ost_r}
                  </p>
                  <p class="pl-4">switchport mode trunk</p>
                  <p class="pl-4">exit</p>
                  <br />
                  <p>interface gig0/2</p>
                  <p class="pl-4">
                    description {side === "WEST" ? t.sections.s03.desc_west_r : t.sections.s03.desc_ost_l}
                  </p>
                  <p class="pl-4">switchport mode trunk</p>
                  <p class="pl-4">exit</p>
                  <br />
                  <p>interface vlan 8</p>
                  <p class="pl-4">ip address {side === "WEST" ? "10.0.8.11" : "10.0.8.22"} 255.255.255.0</p>
                  <p class="pl-4">no shut</p>
                  <p class="pl-4">exit</p>
                  <br />
                  <p>ip default-gateway 10.0.8.1</p>
                </CliBlock>

              </DeviceColumn>
            ))}
          </div>
        </section>

        <section id="core" class="mb-32">
          <h2 class="mb-10 pl-4 text-3xl font-bold text-white tracking-tighter border-l-4 border-blue-500 uppercase">
            {t.sections.s04.l3_title}
          </h2>

          <div class="grid gap-8 lg:grid-cols-2">
            {["WEST", "OST"].map((side) => (
              <DeviceColumn name={side === "WEST" ? "SWITCH GV-L" : "SWITCH GV-R"} side={side} lang={lang as "es" | "de"}>

                <CliBlock title={t.sections.s04.l3_title}>
                  <p>ip routing</p>
                  <p><p>vlan 8</p></p>
                  <p><p>name Management</p></p>
                  <p class="text-slate-500 font-sans italic">» {t.sections.s04.l3_note}</p>
                </CliBlock>

                <CliBlock title={t.sections.s03.security_title}>
                  <p>interface range fa0/1 - 24 ({t.common.example})</p>
                  <p class="pl-4">switchport mode access</p>
                  <p class="pl-4">switchport access vlan {side === "WEST" ? "11" : "21"}</p>
                  <p class="pl-4">spanning-tree portfast</p>
                  <p class="pl-4">switchport port-security</p>
                  <p class="pl-4">switchport port-security maximum 2</p>
                  <p class="pl-4">switchport port-security mac-address sticky</p>
                  <p class="pl-4">switchport port-security violation shutdown</p>
                  <p class="pl-4">spanning-tree bpduguard enable</p>
                  <p class="pl-4">exit</p>
                </CliBlock>

                <CliBlock title={t.sections.s04.hsrp_title}>
                  <p class="text-slate-500 italic">// {side === "WEST" ? t.sections.s04.hsrp_west_main : t.sections.s04.hsrp_ost_main}</p>
                  <p class={side === "WEST" ? "text-red-400" : "text-pink-400"}>interface vlan {side === "WEST" ? "11" : "21"}</p>
                  <p class="pl-4">ip address {side === "WEST" ? "10.0.11.2" : "10.0.21.2"} 255.255.255.0</p>
                  <p class="pl-4">standby {side === "WEST" ? "11" : "21"} ip 10.0.{side === "WEST" ? "11" : "21"}.1</p>
                  <p class="pl-4">standby {side === "WEST" ? "11" : "21"} priority 110</p>
                  <p class="pl-4">standby {side === "WEST" ? "11" : "21"} preempt</p>
                  <p class="pl-4">no shut</p>
                  <p class="pl-4">exit</p>
                  <br />
                  <p class={side === "WEST" ? "text-red-400" : "text-pink-400"}>interface vlan {side === "WEST" ? "12" : "22"}</p>
                  <p class="pl-4">ip address {side === "WEST" ? "10.0.12.2" : "10.0.22.2"} 255.255.255.0</p>
                  <p class="pl-4">standby {side === "WEST" ? "12" : "22"} ip 10.0.{side === "WEST" ? "12" : "22"}.1</p>
                  <p class="pl-4">standby {side === "WEST" ? "12" : "22"} priority 110</p>
                  <p class="pl-4">standby {side === "WEST" ? "12" : "22"} preempt</p>
                  <p class="pl-4">no shut</p>
                  <p class="pl-4">exit</p>
                  <br />
                  <p class="text-slate-500 italic">// {side === "WEST" ? t.sections.s04.hsrp_west_back : t.sections.s04.hsrp_ost_back}</p>
                  <p class={side === "WEST" ? "text-pink-400" : "text-red-400"}>interface vlan {side === "WEST" ? "21" : "11"}</p>
                  <p class="pl-4">ip address {side === "WEST" ? "10.0.21.3" : "10.0.11.3"} 255.255.255.0</p>
                  <p class="pl-4">standby {side === "WEST" ? "21" : "11"} ip 10.0.{side === "WEST" ? "21" : "11"}.1</p>
                  <p class="pl-4">standby {side === "WEST" ? "21" : "11"} priority 100</p>
                  <p class="pl-4">standby {side === "WEST" ? "21" : "11"} preempt</p>
                  <p class="pl-4">no shut</p>
                  <p class="pl-4">exit</p>
                  <br />
                  <p class={side === "WEST" ? "text-pink-400" : "text-red-400"}>interface vlan {side === "WEST" ? "22" : "12"}</p>
                  <p class="pl-4">ip address {side === "WEST" ? "10.0.22.3" : "10.0.12.3"} 255.255.255.0</p>
                  <p class="pl-4">standby {side === "WEST" ? "22" : "12"} ip 10.0.{side === "WEST" ? "22" : "12"}.1</p>
                  <p class="pl-4">standby {side === "WEST" ? "22" : "12"} priority 100</p>
                  <p class="pl-4">standby {side === "WEST" ? "22" : "12"} preempt</p>
                  <p class="pl-4">no shut</p>
                  <p class="pl-4">exit</p>
                  <br />
                  <p class="text-slate-500 italic">» {t.sections.s04.hsrp_mgmt}</p>
                  <p class="text-blue-400">interface vlan 8 <span class="text-black/40">h</span></p>
                  <p class="pl-4">ip address 10.0.8.{side === "WEST" ? "2" : "3"} 255.255.255.0</p>
                  <p class="pl-4">standby 8 ip 10.0.8.1</p>
                  <p class="pl-4">standby 8 priority {side === "WEST" ? "110" : "100"}</p>
                  <p class="pl-4">standby 8 preempt</p>
                  <p class="pl-4">no shut</p>
                  <p class="pl-4">exit</p>
                  <br />
                  <p class="text-slate-500 italic">» {t.sections.s04.hsrp_srv}</p>
                  <p class="text-emerald-400">interface vlan 99</p>
                  <p class="pl-4">ip address 10.0.99.{side === "WEST" ? "2" : "3"} 255.255.255.0</p>
                  <p class="pl-4">standby 99 ip 10.0.99.1</p>
                  <p class="pl-4">standby 99 priority {side === "WEST" ? "110" : "100"}</p>
                  <p class="pl-4">standby 99 preempt</p>
                  <p class="pl-4">no shut</p>
                  <p class="pl-4">exit</p>
                </CliBlock>

                <CliBlock title={t.sections.s04.acl_title}>
                  <p class="text-slate-500 italic">» {t.sections.s04.acl_dc_prot}</p>
                  <p>ip access-list extended SERVER_SECURITY</p>
                  <p class="pl-4">permit ip 10.0.8.0 0.0.0.255 10.0.99.0 0.0.0.255</p>
                  <p class="pl-4">deny ip 10.0.0.0 0.0.255.255 10.0.99.0 0.0.0.255</p>
                  <p class="pl-4">permit ip any any</p>
                  <p class="pl-4">exit</p>
                  <br />
                  <p>interface vlan 99</p>
                  <p class="pl-4">ip access-group SERVER_SECURITY out</p>
                  <br />
                  <p class="text-slate-500 italic">» {t.sections.s04.acl_isol}</p>
                  <p>ip access-list extended {side === "WEST" ? "ACL_WEST" : "ACL_OST"}</p>
                  <p class="pl-4">deny ip 10.0.{side === "WEST" ? "11" : "21"}.0 0.0.1.255 10.0.8.0 0.0.0.255</p>
                  <p class="pl-4">deny ip 10.0.{side === "WEST" ? "11" : "21"}.0 0.0.1.255 10.0.99.0 0.0.0.255</p>
                  <p class="pl-4">deny ip 10.0.{side === "WEST" ? "11" : "21"}.0 0.0.1.255 10.0.{side === "WEST" ? "21" : "11"}.0 0.0.1.255</p>
                  <p class="pl-4">deny ip 10.0.{side === "WEST" ? "11" : "21"}.0 0.0.0.255 10.0.{side === "WEST" ? "12" : "22"}.0 0.0.0.255</p>
                  <p class="pl-4">deny ip 10.0.{side === "WEST" ? "12" : "22"}.0 0.0.0.255 10.0.{side === "WEST" ? "11" : "21"}.0 0.0.0.255</p>
                  <p class="pl-4">deny ip 10.0.{side === "WEST" ? "21" : "11"}.0 0.0.1.255 10.0.{side === "WEST" ? "11" : "21"}.0 0.0.1.255 ({t.common.fail})</p>
